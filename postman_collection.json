						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"monthly_budget\": 5000,\n    \"monthly_income\": 8000\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/user/addMonthlyData",
							"host": ["{{base_url}}"],
							"path": ["api", "user", "addMonthlyData"]
						},
						"description": "Add or update user's monthly budget and income"
					}
				},
				{
					"name": "Get Dashboard Data",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/user/getDashboardData",
							"host": ["{{base_url}}"],
							"path": ["api", "user", "getDashboardData"]
						},
						"description": "Get user's dashboard data including expenses, budgets, and analytics"
					}
				}
			]
		},
		{
			"name": "Expenses",
			"item": [
				{
					"name": "Get All Expenses",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/expense",
