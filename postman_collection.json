				},
				{
					"name": "Get Expense by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/expense/:id",
							"host": ["{{base_url}}"],
							"path": ["api", "expense", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "1",
									"description": "ID of the expense"
								}
							]
						},
						"description": "Get a specific expense by ID"
					}
				},
				{
					"name": "Create Expense",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"category_id\": 1,\n    \"amount\": 100,\n    \"expense_name\": \"Grocery shopping\",\n    \"expense_date\": \"2024-01-01\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/expense",
							"host": ["{{base_url}}"],
							"path": ["api", "expense"]
						},
						"description": "Create a new expense"
					}
				},
				{
					"name": "Delete Expense",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/expense/:id",
							"host": ["{{base_url}}"],
							"path": ["api", "expense", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "1",
									"description": "ID of the expense to delete"
								}
							]
						},
						"description": "Delete an expense"
					}
				}
			]
		},
