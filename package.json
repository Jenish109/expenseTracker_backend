{
    "name": "expense-tracker",
    "version": "1.0.0",
    "description": "A Node.js backend template with MySQL integration",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "nodemon --exec ts-node src/server.ts",
        "test": "jest",
        "migrate": "sequelize-cli db:migrate",
        "migrate:undo": "sequelize-cli db:migrate:undo",
        "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
        "migrate:create": "sequelize-cli migration:generate --name",
        "seed": "sequelize-cli db:seed:all",
        "seed:undo:all": "sequelize-cli db:seed:undo:all",
        "db:reset": "node scripts/reset-db.js && npm run migrate && npm run seed"
    },
    "dependencies": {
        "@types/umzug": "^2.3.9",
        "@types/winston": "^2.4.4",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "cron": "^4.3.2",
        "crypto": "^1.0.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-validator": "^7.2.1",
        "firebase-admin": "^13.4.0",
        "helmet": "^7.1.0",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "mysql2": "^3.6.5",
        "nodemailer": "^7.0.5",
        "sequelize": "^6.37.7",
        "sequelize-cli": "^6.6.3",
        "umzug": "^3.8.2",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.3",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.6",
        "@types/node": "^18.17.20",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.2.2"
    }
}
